{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capabilities for Meridian",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/meridian-daemon", "sidecar": true, "args": true }]
    },
    {
      "identifier": "shell:allow-kill",
      "allow": [{ "name": "binaries/meridian-daemon", "sidecar": true }]
    },
    "notification:default",
    "fs:default",
    "fs:read-files",
    "fs:write-files",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-exists"
  ]
}
